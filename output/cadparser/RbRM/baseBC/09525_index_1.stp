#1129 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-04),#1126,
  'distance_accuracy_value','confusion accuracy');
#1130 = PRODUCT_TYPE('part',$,(#7));
ENDSEC;
