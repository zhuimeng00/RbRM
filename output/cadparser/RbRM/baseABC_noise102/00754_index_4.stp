#638 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#639 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(5.E-03),#636,
  'distance_accuracy_value','confusion accuracy');
#640 = PRODUCT_TYPE('part',$,(#7));
ENDSEC;
END-ISO-10303-21;
